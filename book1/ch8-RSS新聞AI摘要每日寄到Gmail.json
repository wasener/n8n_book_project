        "message": "=<!DOCTYPE html>\n<html lang=\"zh-TW\">\n<head>\n    <meta charset=\"UTF-8\">\n    <title>Daily AI News Digest</title>\n</head>\n<body style=\"margin: 0; padding: 0; background-color: #f4f7f9; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\">\n    <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\">\n        <tr>\n            <td align=\"center\" style=\"padding: 40px 0;\">\n                <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"600\" style=\"max-width: 600px; width: 100%;\">\n                    <tr>\n                        <td style=\"padding: 0 20px 20px 20px; text-align: left;\">\n                            <h1 style=\"margin: 0; font-size: 24px; color: #333; letter-spacing: -0.5px;\">每日重點新聞摘要</h1>\n                            <p style=\"margin: 5px 0 0 0; font-size: 14px; color: #777;\">由 AI 為您整理的最前線動態</p>\n                            <hr style=\"border: 0; border-top: 2px solid #333; margin-top: 15px;\">\n                        </td>\n                    </tr>\n                    \n                    <tr>\n                        <td style=\"padding: 0 20px;\">\n                            {{ $json.html_block }}\n                        </td>\n                    </tr>\n\n                    <tr>\n                        <td style=\"padding: 20px; text-align: center;\">\n                            <p style=\"font-size: 12px; color: #999; margin: 0;\">\n                                本郵件由 n8n 自動化系統發送<br>\n                                © 2026 AI News Assistant. All rights reserved.\n                            </p>\n                        </td>\n                    </tr>\n                </table>\n            </td>\n        </tr>\n    </table>\n</body>\n</html>",
